<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:hc="https://handyorg.github.io/handycontrol"
                    xmlns:ex="clr-namespace:SanGuoCharacterEditor.Extensions"
                    xmlns:m="clr-namespace:SanGuoCharacterEditor.Core.Models"
                    xmlns:hhctrl="clr-namespace:pkHHControlShared.Controls;assembly=pkHHControlShared"
                    xmlns:enums="clr-namespace:SanGuoCharacterEditor.Core.Enums"
                    >

    <Style x:Key="TextBlock.Label2" TargetType="TextBlock" BasedOn="{StaticResource TextBlock.Label}">
        <Setter Property="Margin" Value="6,3,0,3"/>
    </Style>
    <Style TargetType="hhctrl:SearchableComboBox" BasedOn="{StaticResource SearchableComboBox.Small}">
        <Setter Property="Margin" Value="3"/>
    </Style>
    <Style TargetType="hc:NumericUpDown" BasedOn="{StaticResource NumericUpDown.Small}">
        <Setter Property="Padding" Value="3,1"/>
        <Setter Property="Margin" Value="3"/>
    </Style>
    <Style TargetType="hc:TagContainer" BasedOn="{StaticResource TagContainerBaseStyle}">
        <Setter Property="Margin" Value="3"/>
        <Setter Property="Padding" Value="3"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="MinHeight" Value="30"/>
    </Style>
    <Style TargetType="hc:Tag" BasedOn="{StaticResource TagBaseStyle}">
        <Setter Property="Margin" Value="3"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style TargetType="GroupBox" BasedOn="{StaticResource GroupBoxTab.Small}">
        <Setter Property="Margin" Value="3"/>
        <Setter Property="hc:TitleElement.Background" Value="Transparent"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style x:Key="NumericWithTitle" TargetType="hc:NumericUpDown" BasedOn="{StaticResource NumericUpDownExtend.Small}">
        <Setter Property="Padding" Value="3,1"/>
        <Setter Property="Margin" Value="3,3"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="hc:TitleElement.TitlePlacement" Value="Left"/>
        <Setter Property="hc:TitleElement.MarginOnTheLeft" Value="0,0,6,0"/>
        <Setter Property="hc:TitleElement.VerticalAlignment" Value="Center"/>
        <Setter Property="hc:TitleElement.HorizontalAlignment" Value="Right"/>
        <Setter Property="hc:TitleElement.TitleWidth" Value="30"/>
        <Setter Property="ToolTip">
            <Setter.Value>
                <ToolTip>
                    <TextBlock>
                        <TextBlock.Text>
                            <MultiBinding StringFormat="范围:{0}~{1}">
                                <Binding RelativeSource="{RelativeSource AncestorType=hc:NumericUpDown}" Path="Minimum"/>
                                <Binding RelativeSource="{RelativeSource AncestorType=hc:NumericUpDown}" Path="Maximum"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </ToolTip>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="StatEntry" TargetType="hc:NumericUpDown" BasedOn="{StaticResource NumericWithTitle}">
        <Setter Property="Padding" Value="3,1"/>
        <Setter Property="Margin" Value="6,3,3,3"/>
        <Setter Property="Minimum" Value="0"/>
        <Setter Property="Maximum" Value="150"/>
        <Setter Property="hc:TitleElement.TitleWidth" Value="30"/>
        <Setter Property="Width" Value="100"/>
        <Setter Property="MinWidth" Value="100"/>
        <Setter Property="MaxWidth" Value="100"/>
    </Style>
    <Style x:Key="StatAgingEntry" TargetType="hc:ComboBox" BasedOn="{StaticResource ComboBoxWithTitle}">
        <Setter Property="ItemsSource" Value="{ex:EnumBindingSource {x:Type enums:StatAging}}"/>
        <Setter Property="hc:TitleElement.TitleWidth" Value="56"/>
        <Setter Property="Width" Value="160"/>
        <Setter Property="MinWidth" Value="160"/>
        <Setter Property="MaxWidth" Value="160"/>
    </Style>
    <Style x:Key="ArmyLevelEntry" TargetType="hc:ComboBox" BasedOn="{StaticResource ComboBoxWithTitle}">
        <Setter Property="ItemsSource" Value="{x:Static m:GlobalData.ArmyLevelNames}"/>
        <Setter Property="hc:TitleElement.TitleWidth" Value="30"/>
        <Setter Property="Width" Value="120"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="MaxWidth" Value="120"/>
    </Style>
    <Style x:Key="ModelNumeric" TargetType="hc:NumericUpDown" BasedOn="{StaticResource NumericWithTitle}">
        <Setter Property="hc:TitleElement.TitleWidth" Value="30"/>
        <Setter Property="Margin" Value="6,3,3,3"/>
        <Setter Property="Minimum" Value="-1"/>
        <Setter Property="Maximum" Value="127"/>
        <Setter Property="Width" Value="120"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="MaxWidth" Value="120"/>
    </Style>
    <Style x:Key="ModelComboBox" TargetType="hc:ComboBox" BasedOn="{StaticResource ComboBoxWithTitle}">
        <Setter Property="hc:TitleElement.TitleWidth" Value="30"/>
        <Setter Property="Margin" Value="6,3,3,3"/>
        <Setter Property="Width" Value="120"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="MaxWidth" Value="120"/>
    </Style>
</ResourceDictionary>